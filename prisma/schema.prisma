generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  OJ_GOLD
  OJ_INVESTMENT
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum MatchStatus {
  UPCOMING
  LIVE
  FT
  POSTPONED
  CANCELLED
}

enum TipCategory {
  HOME_WIN
  AWAY_WIN
  DOUBLE_CHANCE
  DRAW
  OVER_15
  OVER_25
  OVER_35
  BTTS
  HT_OVER_05
  SURE_2_ODDS
  SURE_3_ODDS
  SURE_5_ODDS
  OJ_BANKER
}

enum TipResult {
  PENDING
  WON
  LOST
  VOID
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  name          String?
  passwordHash  String?
  role          Role      @default(USER)
  emailVerified DateTime?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
  savedTips    SavedTip[]

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Subscription {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  userId      String             @unique @db.ObjectId
  plan        SubscriptionPlan   @default(FREE)
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  paystackRef String?
  autoRenew   Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

model Match {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  apiMatchId   Int?        @unique
  homeTeam     String
  awayTeam     String
  homeTeamLogo String?
  awayTeamLogo String?
  league       String
  leagueLogo   String?
  country      String
  kickoff      DateTime
  homeScore    Int?
  awayScore    Int?
  htHomeScore  Int?
  htAwayScore  Int?
  status       MatchStatus @default(UPCOMING)
  venue        String?
  referee      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tips Tips[]
  h2h  H2HRecord[]

  @@map("matches")
}

model H2HRecord {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  matchId     String   @db.ObjectId
  date        DateTime
  homeTeam    String
  awayTeam    String
  homeScore   Int
  awayScore   Int
  competition String?

  match Match @relation(fields: [matchId], references: [id])

  @@map("h2h_records")
}

model Tips {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  matchId     String      @db.ObjectId
  category    TipCategory
  prediction  String
  odds        Float?
  confidence  Int         @default(50)
  aiAnalysis  String?
  result      TipResult   @default(PENDING)
  vipOnly     Boolean     @default(false)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  match   Match      @relation(fields: [matchId], references: [id])
  savedBy SavedTip[]

  @@map("tips")
}

model SavedTip {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  tipId     String   @db.ObjectId
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  tip  Tips @relation(fields: [tipId], references: [id])

  @@unique([userId, tipId])
  @@map("saved_tips")
}

model BlogPost {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  coverImage  String?
  authorId    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  tags        String[]
  seoTitle    String?
  seoDesc     String?
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model Ad {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  imageUrl    String
  linkUrl     String
  position    String   @default("sidebar")
  active      Boolean  @default(true)
  clicks      Int      @default(0)
  impressions Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ads")
}
